# Kamarooms Ops — Environment Variables
# Copy to .env and fill in values

# -- 1C Integration -------------------------------------------------------
1C_API_URL=
1C_USERNAME=
1C_PASSWORD=

# -- Travelline (channel manager) -----------------------------------------
TRAVELLINE_API_KEY=
TRAVELLINE_HOTEL_ID=

# -- Bitrix24 (CRM) -------------------------------------------------------
BITRIX_DOMAIN=crm.spa-list.ru
BITRIX_WEBHOOK_TOKEN=

# -- Yandex Cloud (analytics DB target) -----------------------------------
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# -- Anthropic (Claude API) -----------------------------------------------
ANTHROPIC_API_KEY=

# -- GitHub (auto-commit) -------------------------------------------------
GITHUB_TOKEN=

# -- Paths (optional — defaults work for standard install) -----------------
# KAMAROOMS_OPS_DIR=/home/ed/kamarooms-ops
# DASHBOARD_OUTPUT_DIR=dashboard/dist
